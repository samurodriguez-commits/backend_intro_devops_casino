# ============================================================
# Variables de entorno del backend del casino
# Copiar a .env (NO commitear el .env real)
# ============================================================

PORT=3000
JWT_SECRET=cambiame-en-produccion
JWT_EXPIRES_IN=8h

# Postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=casino
DB_PASSWORD=casino
DB_NAME=casino_db

# CORS: dominios permitidos separados por coma. * para abierto en dev.
CORS_ORIGIN=*
